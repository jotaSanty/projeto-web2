@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4">Sistema de Cadastro de Produtos</h1>
    <p class="lead">Gerencie seus produtos de forma simples e rápida.</p>
    <a class="btn btn-primary btn-lg mt-3" href="/Produto">Ver Produtos</a>
</div>

<div class="row mt-5">
    <div class="col-md-4 text-center">
        <h3>📦 Cadastrar</h3>
        <p>Adicione novos produtos ao sistema com nome, preço e quantidade.</p>
    </div>
    <div class="col-md-4 text-center">
        <h3>✏️ Editar</h3>
        <p>Atualize as informações dos produtos sempre que necessário.</p>
    </div>
    <div class="col-md-4 text-center">
        <h3>🗑️ Excluir</h3>
        <p>Remova produtos que não fazem mais parte do estoque.</p>
    </div>
</div>